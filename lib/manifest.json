  "api": {
    "parseGoal": {
      "signature": "parseGoal(goalText: string): ParsedGoal",
      "description": "Parse a single goal string",
      "returns": {
        "goal": "string - original goal text",
        "pattern": "string - detected pattern type",
        "components": "object with quantifier, categories, etc.",
        "subtasks": "array of task objects with dependencies",
        "dependencies": "object mapping domain areas to constraints",
        "acceptance_criteria": "array of completion criteria",
        "metadata": "object with complexity, scope, phases"
      }
    },
    "parseGoals": {
      "signature": "parseGoals(goals: string[]): ParsedGoal[]",
      "description": "Batch parse multiple goal strings",
      "returns": "array of ParsedGoal objects"
    },
    "formatGoal": {
      "signature": "formatGoal(parsed: ParsedGoal): string",
      "description": "Format parsed goal as human-readable text",
      "returns": "formatted string with all phases, tasks, and criteria"
    }
  },

  "patterns": {
    "add": {
      "regex": "/^(?:add|implement|integrate|enable)\\s+([^,]+?)\\s+(?:to|across|on|in)\\s+(.+)$/i",
      "examples": ["Add OAuth2 to API", "Add OAuth2 + SAML across 15 microservices"]
    },
    "distribute": {
      "regex": "/^(?:implement|deploy|integrate|add)\\s+([^,]+?)\\s+across\\s+(\\d+)\\s+([^.]+?)(?:\\.|$)/i",
      "examples": ["Implement feature flags across 20 services"]
    },
    "integrate": {
      "regex": "/^(?:integrate|combine|merge|add)\\s+([^.]+?)\\s+(?:and|with)\\s+([^.]+?)(?:\\s+(?:to|across|in|on)\\s+(.+))?$/i",
      "examples": ["Integrate Redis and PostgreSQL"]
    },
    "build": {
      "regex": "/^(?:build|create|develop|implement)\\s+([^,]+?)\\s+for\\s+(.+)$/i",
      "examples": ["Build authentication layer for mobile app"]
    },
    "setup": {
      "regex": "/^(?:setup|configure|install|enable)\\s+([^,]+?)\\s+with\\s+(.+)$/i",
      "examples": ["Setup PostgreSQL with replication"]
    }
  },

