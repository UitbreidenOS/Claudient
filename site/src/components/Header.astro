---
const navItems = [
  { label: "Skills", href: "/skills/" },
  { label: "Agents", href: "/agents/" },
  { label: "Hooks", href: "/hooks/" },
  { label: "MCP", href: "/mcp/" },
  { label: "Guides", href: "/guides/" },
];
---

<header
  class="sticky top-0 z-40 border-b backdrop-blur"
  style="background-color: color-mix(in srgb, var(--color-bg) 80%, transparent); border-color: var(--color-border);"
>
  <div class="container-page flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 font-semibold text-lg tracking-tight">
      <span
        class="inline-flex items-center justify-center w-7 h-7 rounded-md text-white font-bold text-sm"
        style="background-color: var(--color-accent);"
      >
        C
      </span>
      <span>Claudient</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="px-3 py-1.5 rounded-md text-sm font-medium hover:bg-[var(--color-bg-elevated)] transition-colors"
            style="color: var(--color-fg);"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="https://github.com/Claudient/Claudient"
        target="_blank"
        rel="noopener"
        class="btn-ghost hidden sm:inline-flex"
        aria-label="GitHub"
      >
        GitHub
      </a>
      <a href="/install/" class="btn-primary">
        Install
      </a>
    </div>
  </div>
</header>
