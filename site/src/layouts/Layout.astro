---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  ogImage?: string;
  /**
   * Controls hreflang alternate emission:
   * - undefined (default): auto-detect from path — collection pages get all locales,
   *   non-collection pages (install, about, contribute, search, home, 404) get none.
   * - string[] (e.g. ["fr","de"]): emit only those locales.
   * - [] (empty array): emit NO hreflang (use for static pages without translations).
   */
  translatedLocales?: string[];
}

const {
  title,
  description = "The Claude Code knowledge base — 277+ skills, 95+ agents, 30+ hooks, 30+ MCP configs for Claude Code. Open source, multi-language, free to use.",
  canonical,
  jsonLd,
  ogImage: ogImageProp,
  translatedLocales,
} = Astro.props;

const siteUrl = "https://claudient.tools";

// Derive current locale and canonical path (without locale prefix) from the URL.
const SUPPORTED_LOCALES = ["fr", "de", "nl", "es"];
const ALL_LOCALES = ["en", ...SUPPORTED_LOCALES];

const rawPath = Astro.url.pathname;
const segs = rawPath.split("/").filter(Boolean);
const hasLocalePrefix = segs[0] && SUPPORTED_LOCALES.includes(segs[0]);
const currentLocale = hasLocalePrefix ? segs[0] : "en";
// Canonical path is the locale-stripped path, always ending in "/".
const canonicalPath = hasLocalePrefix
  ? ("/" + segs.slice(1).join("/") + "/").replace(/\/+$/, "/")
  : rawPath.endsWith("/") ? rawPath : rawPath + "/";

const canonicalUrl = canonical ?? `${siteUrl}${canonicalPath}`;

// Collections that have translated versions under /[lang]/.
// Only pages whose first path segment matches one of these will get hreflang alternates.
const TRANSLATED_COLLECTIONS = new Set([
  "skills", "agents", "hooks", "mcp", "guides", "prompts", "rules", "workflows",
]);

// Determine which locales to emit hreflang for:
// 1. If translatedLocales is explicitly passed, use it ([] = no hreflang).
// 2. Otherwise auto-detect: emit all locales for known collection paths, none otherwise.
const pathFirstSeg = canonicalPath.split("/").filter(Boolean)[0] ?? "";
const autoHreflangLocales = TRANSLATED_COLLECTIONS.has(pathFirstSeg) ? ALL_LOCALES : [];
const hreflangLocales: string[] =
  translatedLocales !== undefined ? ["en", ...translatedLocales.filter((l) => l !== "en")] : autoHreflangLocales;

// Derive per-page SVG OG image from the canonical URL path.
// Pattern: /{collection}/{...slug}/ → /og/{collection}/{...slug}.svg
// Falls back to the static default for non-collection pages.
const DETAIL_COLLECTIONS = new Set([
  "skills", "agents", "hooks", "mcp", "workflows", "guides", "prompts", "rules",
]);
function deriveOgImage(url: string): string {
  try {
    const { pathname } = new URL(url);
    const parts = pathname.replace(/^\/|\/$/g, "").split("/").filter(Boolean);
    // Must have at least 2 segments: collection + slug
    if (parts.length >= 2 && DETAIL_COLLECTIONS.has(parts[0])) {
      return `${siteUrl}/og/${parts.join("/")}.svg`;
    }
  } catch {
    // malformed URL — fall through to default
  }
  return `${siteUrl}/og-default.png`;
}

const ogImage = ogImageProp ?? deriveOgImage(canonicalUrl);
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Hreflang alternates — only emitted for pages with translated versions. */}
    {hreflangLocales.length > 0 && (
      <>
        {hreflangLocales.map((locale) => (
          <link
            rel="alternate"
            hreflang={locale}
            href={locale === "en"
              ? `${siteUrl}${canonicalPath}`
              : `${siteUrl}/${locale}${canonicalPath}`}
          />
        ))}
        <link rel="alternate" hreflang="x-default" href={`${siteUrl}${canonicalPath}`} />
      </>
    )}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Claudient" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#fafaf9" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
