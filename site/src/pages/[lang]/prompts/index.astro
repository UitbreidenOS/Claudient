---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import CollectionIndex from "../../../components/CollectionIndex.astro";
import { pathToParts, SUPPORTED_LOCALES } from "../../../lib/content";

export async function getStaticPaths() {
  const nonDefault = SUPPORTED_LOCALES.filter((l) => l !== "en");
  return nonDefault.map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props;
const allEntries = await getCollection("prompts", ({ data }) => !data.draft);
const entries = allEntries.filter((e) => pathToParts(e.id).locale === lang);
---

<Layout
  title="Prompts | Claudient"
  description="Reusable prompt templates for Claude Code — system prompts, project starters, task-specific prompts."
>
  <CollectionIndex
    title="Prompts"
    description="Reusable prompt templates — system prompts, project starters, task-specific kickoff prompts."
    entries={entries}
    collection="prompts"
  />
</Layout>
