---
import { getCollection, render } from "astro:content";
import DocLayout from "../../../layouts/DocLayout.astro";
import { titleFromEntry, descriptionFromEntry, pathToParts, SUPPORTED_LOCALES } from "../../../lib/content";

export async function getStaticPaths() {
  const entries = await getCollection("guides", ({ data }) => !data.draft);
  const nonDefault = SUPPORTED_LOCALES.filter((l) => l !== "en");
  const paths = [];

  for (const entry of entries) {
    const { locale } = pathToParts(entry.id);
    if (!nonDefault.includes(locale)) continue;

    const rawId = entry.id.replace(/\.md$/, "");
    // Match entries whose id contains "claude-for-" (e.g. "fr/claude-for-solopreneurs")
    if (!rawId.includes("claude-for-")) continue;

    const match = rawId.match(/claude-for-(.+)$/);
    if (!match) continue;
    const urlSlug = match[1];

    paths.push({
      params: { lang: locale, slug: urlSlug },
      props: { entry, locale },
    });
  }

  return paths;
}

const { entry, locale } = Astro.props;
const { Content } = await render(entry);
const title = titleFromEntry(entry);
const description = descriptionFromEntry(entry);
const lang = locale;
---

<DocLayout
  title={title}
  description={description}
  collection="claude-for"
  collectionLabel="Claude for Business"
  breadcrumbs={[
    { label: "Home", href: `/${lang}/` },
    { label: "Claude for Your Business", href: `/${lang}/claude-for/` },
    { label: title },
  ]}
>
  <Content />
</DocLayout>
