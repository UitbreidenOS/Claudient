---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import CollectionIndex from "../../../components/CollectionIndex.astro";
import { pathToParts, SUPPORTED_LOCALES } from "../../../lib/content";

export async function getStaticPaths() {
  const nonDefault = SUPPORTED_LOCALES.filter((l) => l !== "en");
  return nonDefault.map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props;
const allEntries = await getCollection("guides", ({ data }) => !data.draft);
const entries = allEntries.filter((e) => pathToParts(e.id).locale === lang);
---

<Layout
  title="Guides | Claudient"
  description="In-depth guides for Claude Code — getting started, agent frontmatter, hooks cookbook, token optimization, multi-agent patterns, and more."
>
  <CollectionIndex
    title="Guides"
    description="In-depth guides for Claude Code — the reference material for everything you build with the agent."
    entries={entries}
    collection="guides"
  />
</Layout>
