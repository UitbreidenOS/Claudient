---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import CollectionIndex from "../../../components/CollectionIndex.astro";
import { pathToParts, SUPPORTED_LOCALES } from "../../../lib/content";

export async function getStaticPaths() {
  const nonDefault = SUPPORTED_LOCALES.filter((l) => l !== "en");
  return nonDefault.map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props;
const allEntries = await getCollection("agents", ({ data }) => !data.draft);
const entries = allEntries.filter((e) => pathToParts(e.id).locale === lang);
---

<Layout
  title="Agents | Claudient"
  description="Specialist Claude Code agents — C-suite advisors, engineering specialists, domain experts. Each with specific model guidance and tool restrictions."
>
  <CollectionIndex
    title="Agents"
    description="Specialist agents you can spawn with the Agent tool in Claude Code. Each has a specific model, tool subset, and trigger conditions."
    entries={entries}
    collection="agents"
  />
</Layout>
