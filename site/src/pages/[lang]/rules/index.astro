---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import CollectionIndex from "../../../components/CollectionIndex.astro";
import { pathToParts, SUPPORTED_LOCALES } from "../../../lib/content";

export async function getStaticPaths() {
  const nonDefault = SUPPORTED_LOCALES.filter((l) => l !== "en");
  return nonDefault.map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props;
const allEntries = await getCollection("rules", ({ data }) => !data.draft);
const entries = allEntries.filter((e) => pathToParts(e.id).locale === lang);
---

<Layout
  title="Rules | Claudient"
  description="Always-follow Claude Code guidelines — coding style, git, security, testing, language-specific best practices."
>
  <CollectionIndex
    title="Rules"
    description="Always-follow Claude Code guidelines for projects — coding style, git, security, testing."
    entries={entries}
    collection="rules"
  />
</Layout>
