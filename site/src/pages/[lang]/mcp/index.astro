---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import CollectionIndex from "../../../components/CollectionIndex.astro";
import { pathToParts, SUPPORTED_LOCALES } from "../../../lib/content";

export async function getStaticPaths() {
  const nonDefault = SUPPORTED_LOCALES.filter((l) => l !== "en");
  return nonDefault.map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props;
const allEntries = await getCollection("mcp", ({ data }) => !data.draft);
const entries = allEntries.filter((e) => pathToParts(e.id).locale === lang);
---

<Layout
  title="MCP servers | Claudient"
  description="Curated Model Context Protocol server configurations for Claude Code. GitHub, Figma, Stripe, Notion, Linear, Playwright, and 25+ more."
>
  <CollectionIndex
    title="MCP servers"
    description="The fastest way to extend Claude Code. MCP servers give Claude direct access to your tools — GitHub, Figma, Stripe, Notion, Slack, and more."
    entries={entries}
    collection="mcp"
  />
</Layout>
