---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import CollectionIndex from "../../../components/CollectionIndex.astro";
import { pathToParts, SUPPORTED_LOCALES } from "../../../lib/content";

export async function getStaticPaths() {
  const nonDefault = SUPPORTED_LOCALES.filter((l) => l !== "en");
  return nonDefault.map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props;
const allEntries = await getCollection("skills", ({ data }) => !data.draft);
const entries = allEntries.filter((e) => pathToParts(e.id).locale === lang);
---

<Layout
  title="Skills | Claudient"
  description="Every Claudient skill — drop-in domain expertise for Claude Code. Backend, AI engineering, small business, GTM, legal, finance, and more."
>
  <CollectionIndex
    title="Skills"
    description="Drop-in domain expertise for Claude Code. Each skill activates automatically based on what you're working on."
    entries={entries}
    collection="skills"
  />
</Layout>
