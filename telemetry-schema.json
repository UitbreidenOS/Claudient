{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Matrix Theme Telemetry Schema",
  "description": "Comprehensive telemetry tracking for Matrix theme usage, customization, performance, and errors. Respects opt-in consent model.",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for versioning telemetry payloads"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the event was generated"
    },
    "sessionId": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$",
      "description": "Unique session identifier (MD5 hash, no PII)"
    },
    "userId": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$",
      "description": "Anonymous user hash (MD5 hash derived from system hostname + username, no PII)"
    },
    "consent": {
      "type": "object",
      "required": ["enabled", "consentVersion", "timestamp"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether telemetry collection is enabled. Must be true to send any telemetry."
        },
        "consentVersion": {
          "type": "string",
          "description": "Version of consent agreement accepted by user"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When consent was given or updated"
        },
        "categories": {
          "type": "object",
          "description": "Fine-grained consent categories",
          "properties": {
            "themeSelection": {
              "type": "boolean",
              "default": true,
              "description": "Allow tracking theme selection events"
            },
            "customization": {
              "type": "boolean",
              "default": true,
              "description": "Allow tracking customization changes"
            },
            "performance": {
              "type": "boolean",
              "default": true,
              "description": "Allow tracking performance metrics"
            },
            "errors": {
              "type": "boolean",
              "default": true,
              "description": "Allow tracking errors and crashes"
            },
            "usage": {
              "type": "boolean",
              "default": false,
              "description": "Allow tracking feature usage patterns"
            }
          }
        }
      }
    },
    "event": {
      "type": "object",
      "required": ["type", "category"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "THEME_SELECTED",
            "THEME_ACTIVATED",
            "THEME_DEACTIVATED",
            "CUSTOMIZATION_CHANGED",
            "CUSTOMIZATION_RESET",
            "CUSTOMIZATION_EXPORTED",
            "CUSTOMIZATION_IMPORTED",
            "EFFECT_TOGGLED",
            "COLOR_MODIFIED",
            "FONT_CHANGED",
            "SPACING_ADJUSTED",
            "PERFORMANCE_MEASURED",
            "ERROR_OCCURRED",
            "FEATURE_USED",
            "SETTING_CHANGED",
            "COMPONENT_RENDERED",
            "ANIMATION_PLAYED",
            "ACCESSIBILITY_TOGGLED"
          ],
          "description": "Event type identifier"
        },
        "category": {
          "type": "string",
          "enum": [
            "theme_selection",
            "customization",
            "performance",
            "error",
            "usage",
            "accessibility"
          ],
          "description": "Event category for filtering and analytics"
        },
        "source": {
          "type": "string",
          "enum": ["claude_code", "plugin", "api", "cli", "settings_ui"],
          "description": "Source of the event"
        },
        "properties": {
          "type": "object",
          "description": "Event-specific properties"
        }
      }
    },
    "themeSelection": {
      "type": "object",
      "description": "Theme selection tracking",
      "properties": {
        "eventType": {
          "type": "string",
          "const": "THEME_SELECTED",
          "description": "Event type for theme selection"
        },
        "data": {
          "type": "object",
          "required": ["themeName", "version"],
          "properties": {
            "themeName": {
              "type": "string",
              "const": "Matrix",
              "description": "Name of selected theme"
            },
            "version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$",
              "description": "Theme version (semantic versioning)"
            },
            "previousTheme": {
              "type": "string",
              "description": "Previously active theme name (if applicable)"
            },
            "previousVersion": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$",
              "description": "Previously active theme version"
            },
            "switchReason": {
              "type": "string",
              "enum": ["user_choice", "system_upgrade", "profile_sync", "first_install", "unknown"],
              "description": "Reason for theme switch"
            },
            "deploymentContext": {
              "type": "string",
              "enum": ["local", "remote", "plugin", "extension"],
              "description": "Where theme was deployed from"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "When theme selection occurred"
            }
          }
        }
      }
    },
    "customization": {
      "type": "object",
      "description": "Theme customization tracking",
      "properties": {
        "eventType": {
          "type": "string",
          "const": "CUSTOMIZATION_CHANGED",
          "description": "Event type for customization change"
        },
        "data": {
          "type": "object",
          "required": ["customizationType", "changeCount"],
          "properties": {
            "customizationType": {
              "type": "string",
              "enum": [
                "color_primary",
                "color_secondary",
                "color_accent",
                "color_background",
                "color_text",
                "font_family",
                "font_size",
                "font_weight",
                "spacing_value",
                "border_radius",
                "shadow_blur",
                "glow_intensity",
                "scanline_opacity",
                "animation_duration",
                "effect_enabled",
                "effect_disabled",
                "component_style",
                "gradient_modification",
                "palette_preset"
              ],
              "description": "Type of customization applied"
            },
            "changeCount": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of changes in this event"
            },
            "modifications": {
              "type": "array",
              "description": "List of specific modifications",
              "items": {
                "type": "object",
                "required": ["path", "oldValue", "newValue"],
                "properties": {
                  "path": {
                    "type": "string",
                    "description": "JSON path to modified property (e.g., 'colors.primary', 'effects.glow.intensity')"
                  },
                  "oldValue": {
                    "type": "string",
                    "description": "Previous value (stringified)"
                  },
                  "newValue": {
                    "type": "string",
                    "description": "New value (stringified)"
                  },
                  "dataType": {
                    "type": "string",
                    "enum": ["color", "number", "string", "boolean", "array", "object"],
                    "description": "Data type of the modified property"
                  }
                }
              }
            },
            "customizationFrequency": {
              "type": "string",
              "enum": ["first_time", "occasional", "frequent", "power_user"],
              "description": "User's customization frequency (inferred from history)"
            },
            "customizationTime": {
              "type": "integer",
              "minimum": 0,
              "description": "Time spent customizing (in seconds)"
            },
            "sessionCustomizationCount": {
              "type": "integer",
              "minimum": 1,
              "description": "Total customizations in this session"
            },
            "resetAfterCustomization": {
              "type": "boolean",
              "description": "Whether user reset theme after this customization"
            },
            "exportAfterCustomization": {
              "type": "boolean",
              "description": "Whether user exported config after customization"
            }
          }
        }
      }
    },
    "customizationFrequency": {
      "type": "object",
      "description": "Customization frequency tracking",
      "properties": {
        "eventType": {
          "type": "string",
          "const": "CUSTOMIZATION_FREQUENCY",
          "description": "Event type for customization frequency"
        },
        "data": {
          "type": "object",
          "required": ["timeWindow"],
          "properties": {
            "timeWindow": {
              "type": "string",
              "enum": ["session", "daily", "weekly", "monthly"],
              "description": "Time window for aggregation"
            },
            "customizationCount": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of customizations in window"
            },
            "uniquePropertiesModified": {
              "type": "array",
              "description": "Properties modified (aggregated)",
              "items": {
                "type": "string"
              }
            },
            "topModifiedProperties": {
              "type": "array",
              "description": "Most frequently modified properties",
              "items": {
                "type": "object",
                "properties": {
                  "property": {
                    "type": "string"
                  },
                  "count": {
                    "type": "integer"
                  }
                }
              }
            },
            "userSegment": {
              "type": "string",
              "enum": ["non_customizer", "light_customizer", "moderate_customizer", "heavy_customizer", "expert_customizer"],
              "description": "User customization behavior segment"
            }
          }
        }
      }
    },
    "performance": {
      "type": "object",
      "description": "Performance metrics for theme rendering and effects",
      "properties": {
        "eventType": {
          "type": "string",
          "const": "PERFORMANCE_MEASURED",
          "description": "Event type for performance metrics"
        },
        "data": {
          "type": "object",
          "required": ["metricType"],
          "properties": {
            "metricType": {
              "type": "string",
              "enum": [
                "theme_load_time",
                "theme_apply_time",
                "customization_apply_time",
                "component_render_time",
                "animation_frame_rate",
                "memory_usage",
                "cpu_usage",
                "effect_performance",
                "startup_time",
                "theme_switch_time"
              ],
              "description": "Type of performance metric"
            },
            "themeLoadTime": {
              "type": "object",
              "description": "Time to load and parse theme configuration",
              "properties": {
                "value": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Time in milliseconds"
                },
                "percentile": {
                  "type": "string",
                  "enum": ["p50", "p75", "p90", "p95", "p99"],
                  "description": "Performance percentile"
                }
              }
            },
            "themeApplyTime": {
              "type": "object",
              "description": "Time to apply theme to all components",
              "properties": {
                "value": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Time in milliseconds"
                },
                "componentsAffected": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Number of components updated"
                }
              }
            },
            "customizationApplyTime": {
              "type": "object",
              "description": "Time to apply customization changes",
              "properties": {
                "value": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Time in milliseconds"
                },
                "changeCount": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Number of properties changed"
                },
                "timePerChange": {
                  "type": "number",
                  "description": "Average time per change in milliseconds"
                }
              }
            },
            "animationFrameRate": {
              "type": "object",
              "description": "Animation performance metrics",
              "properties": {
                "avgFps": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 60,
                  "description": "Average frames per second"
                },
                "minFps": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 60,
                  "description": "Minimum FPS during animation"
                },
                "droppedFrames": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Number of dropped frames"
                },
                "effectsEnabled": {
                  "type": "array",
                  "description": "Active effects during measurement",
                  "items": {
                    "type": "string",
                    "enum": ["scanlines", "glow", "glitch", "crt_curvature", "vignette"]
                  }
                }
              }
            },
            "memoryUsage": {
              "type": "object",
              "description": "Memory consumption metrics",
              "properties": {
                "heapUsedMb": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Heap memory used in MB"
                },
                "heapTotalMb": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Total heap memory in MB"
                },
                "externalMemoryMb": {
                  "type": "number",
                  "minimum": 0,
                  "description": "External memory in MB"
                },
                "themeMemoryMb": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Memory used by theme resources"
                }
              }
            },
            "cpuUsage": {
              "type": "object",
              "description": "CPU usage during theme operations",
              "properties": {
                "percentage": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100,
                  "description": "CPU usage percentage"
                },
                "duration": {
                  "type": "number",
                  "description": "Duration of measurement in milliseconds"
                }
              }
            },
            "effectPerformance": {
              "type": "object",
              "description": "Individual effect performance",
              "properties": {
                "effectName": {
                  "type": "string",
                  "enum": ["scanlines", "glow", "glitch", "crt_curvature", "vignette", "terminal_cursor", "typewriter"],
                  "description": "Name of effect"
                },
                "renderTime": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Time to render effect in milliseconds"
                },
                "memoryOverhead": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Additional memory used by effect in MB"
                },
                "gpuUtilization": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100,
                  "description": "GPU utilization percentage"
                }
              }
            },
            "startupTime": {
              "type": "object",
              "description": "Application startup time with theme",
              "properties": {
                "coldStart": {
                  "type": "number",
                  "minimum": 0,
                  "description": "First launch time in milliseconds"
                },
                "warmStart": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Subsequent launch time in milliseconds"
                }
              }
            },
            "environmentMetadata": {
              "type": "object",
              "description": "Environment context for performance",
              "properties": {
                "osName": {
                  "type": "string",
                  "enum": ["macOS", "Linux", "Windows", "unknown"],
                  "description": "Operating system"
                },
                "osVersion": {
                  "type": "string",
                  "description": "OS version (not unique identifier)"
                },
                "nodeVersion": {
                  "type": "string",
                  "description": "Node.js version"
                },
                "claudeCodeVersion": {
                  "type": "string",
                  "description": "Claude Code version"
                },
                "screenResolution": {
                  "type": "object",
                  "properties": {
                    "width": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "height": {
                      "type": "integer",
                      "minimum": 0
                    }
                  }
                },
                "devicePixelRatio": {
                  "type": "number",
                  "minimum": 1
                }
              }
            }
          }
        }
      }
    },
    "errorTracking": {
      "type": "object",
      "description": "Error and crash tracking",
      "properties": {
        "eventType": {
          "type": "string",
          "const": "ERROR_OCCURRED",
          "description": "Event type for errors"
        },
        "data": {
          "type": "object",
          "required": ["errorType", "errorCode"],
          "properties": {
            "errorType": {
              "type": "string",
              "enum": [
                "parse_error",
                "apply_error",
                "render_error",
                "animation_error",
                "customization_error",
                "import_error",
                "export_error",
                "memory_error",
                "compatibility_error",
                "permission_error",
                "unknown_error"
              ],
              "description": "Category of error"
            },
            "errorCode": {
              "type": "string",
              "pattern": "^MATRIX_[A-Z0-9_]{3,20}$",
              "description": "Error code identifier (e.g., MATRIX_PARSE_INVALID_JSON)"
            },
            "errorMessage": {
              "type": "string",
              "maxLength": 500,
              "description": "Error message (sanitized, no sensitive data)"
            },
            "stackTrace": {
              "type": "string",
              "description": "Stack trace (sanitized)"
            },
            "affectedComponent": {
              "type": "string",
              "enum": [
                "color_parser",
                "animation_engine",
                "effect_renderer",
                "customization_engine",
                "import_export",
                "component_manager",
                "unknown"
              ],
              "description": "Which component triggered the error"
            },
            "severity": {
              "type": "string",
              "enum": ["info", "warning", "error", "critical"],
              "description": "Error severity level"
            },
            "recoveryAction": {
              "type": "string",
              "enum": ["auto_recover", "fallback_to_default", "manual_reset", "none"],
              "description": "How error was handled"
            },
            "userAction": {
              "type": "string",
              "description": "What user was doing when error occurred"
            },
            "reproducible": {
              "type": "boolean",
              "description": "Whether error is consistently reproducible"
            },
            "occurrenceCount": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of times this error occurred in session"
            },
            "firstOccurrence": {
              "type": "string",
              "format": "date-time",
              "description": "When error first occurred in session"
            },
            "lastOccurrence": {
              "type": "string",
              "format": "date-time",
              "description": "When error last occurred in session"
            }
          }
        }
      }
    },
    "featureUsage": {
      "type": "object",
      "description": "Feature usage tracking (optional, requires explicit consent)",
      "properties": {
        "eventType": {
          "type": "string",
          "const": "FEATURE_USED",
          "description": "Event type for feature usage"
        },
        "data": {
          "type": "object",
          "required": ["featureName"],
          "properties": {
            "featureName": {
              "type": "string",
              "enum": [
                "theme_switcher",
                "color_customizer",
                "font_editor",
                "effect_toggler",
                "animation_adjuster",
                "preset_manager",
                "import_config",
                "export_config",
                "reset_to_default",
                "dark_mode_toggle",
                "accessibility_settings",
                "performance_optimizer",
                "help_menu",
                "settings_panel",
                "live_preview",
                "keyboard_shortcuts"
              ],
              "description": "Feature that was used"
            },
            "usageCount": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of times feature was used in session"
            },
            "sessionTimeWithFeature": {
              "type": "integer",
              "minimum": 0,
              "description": "Time spent using feature in session (seconds)"
            },
            "userIntentRating": {
              "type": "string",
              "enum": ["accidental", "exploratory", "intentional", "repeated"],
              "description": "Inferred user intent with feature"
            },
            "featureContext": {
              "type": "string",
              "description": "Context in which feature was used"
            },
            "successRate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Estimated success rate (0-1)"
            }
          }
        }
      }
    },
    "accessibility": {
      "type": "object",
      "description": "Accessibility feature tracking",
      "properties": {
        "eventType": {
          "type": "string",
          "const": "ACCESSIBILITY_TOGGLED",
          "description": "Event type for accessibility changes"
        },
        "data": {
          "type": "object",
          "required": ["accessibilityFeature"],
          "properties": {
            "accessibilityFeature": {
              "type": "string",
              "enum": [
                "high_contrast_mode",
                "reduced_motion",
                "screen_reader_support",
                "focus_indicators",
                "keyboard_navigation",
                "reduced_animation",
                "large_text_mode",
                "dyslexia_friendly_font",
                "color_blindness_mode",
                "simplified_ui"
              ],
              "description": "Accessibility feature toggled"
            },
            "enabled": {
              "type": "boolean",
              "description": "Whether feature was enabled or disabled"
            },
            "alternativeContrast": {
              "type": "object",
              "description": "Contrast ratio when using accessibility features",
              "properties": {
                "contrastRatio": {
                  "type": "number",
                  "minimum": 1,
                  "description": "WCAG contrast ratio"
                },
                "wcagLevel": {
                  "type": "string",
                  "enum": ["AA", "AAA"],
                  "description": "WCAG compliance level"
                }
              }
            },
            "systemAccessibilitySettings": {
              "type": "array",
              "description": "System-level accessibility settings detected",
              "items": {
                "type": "string",
                "enum": ["system_dark_mode", "system_high_contrast", "system_reduce_motion", "system_large_text"]
              }
            }
          }
        }
      }
    },
    "analyticsAggregation": {
      "type": "object",
      "description": "Pre-aggregated analytics for batch reporting",
      "properties": {
        "aggregationType": {
          "type": "string",
          "enum": ["hourly", "daily", "weekly", "monthly"],
          "description": "Time window for aggregation"
        },
        "periodStart": {
          "type": "string",
          "format": "date-time",
          "description": "Start of aggregation period"
        },
        "periodEnd": {
          "type": "string",
          "format": "date-time",
          "description": "End of aggregation period"
        },
        "activeUsers": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of unique users (hashed) in period"
        },
        "totalSessions": {
          "type": "integer",
          "minimum": 0,
          "description": "Total sessions in period"
        },
        "totalEventsCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Total events recorded"
        },
        "themeAdoptionRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Percentage of theme selections"
        },
        "averageCustomizationsPerSession": {
          "type": "number",
          "minimum": 0,
          "description": "Average customizations per active session"
        },
        "errorRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Percentage of sessions with errors"
        },
        "topErrors": {
          "type": "array",
          "description": "Most frequent errors in period",
          "items": {
            "type": "object",
            "properties": {
              "errorCode": {
                "type": "string"
              },
              "count": {
                "type": "integer"
              },
              "percentageOfTotal": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              }
            }
          }
        },
        "mostUsedFeatures": {
          "type": "array",
          "description": "Most frequently used features",
          "items": {
            "type": "object",
            "properties": {
              "featureName": {
                "type": "string"
              },
              "usageCount": {
                "type": "integer"
              },
              "percentageOfUsers": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              }
            }
          }
        },
        "performanceMetrics": {
          "type": "object",
          "description": "Aggregated performance data",
          "properties": {
            "avgThemeLoadTime": {
              "type": "number",
              "description": "Average theme load time in ms"
            },
            "p95ThemeLoadTime": {
              "type": "number",
              "description": "95th percentile theme load time in ms"
            },
            "avgAnimationFps": {
              "type": "number",
              "description": "Average animation FPS"
            },
            "medianMemoryUsage": {
              "type": "number",
              "description": "Median memory usage in MB"
            }
          }
        },
        "customizationTrends": {
          "type": "object",
          "description": "Trends in customization behavior",
          "properties": {
            "mostModifiedProperties": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "property": {
                    "type": "string"
                  },
                  "modificationCount": {
                    "type": "integer"
                  }
                }
              }
            },
            "customizationSegments": {
              "type": "object",
              "properties": {
                "nonCustomizers": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100,
                  "description": "Percentage of non-customizers"
                },
