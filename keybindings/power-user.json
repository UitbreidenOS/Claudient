# keybindings.json
# Merge this into your ~/.claude/keybindings.json for the Power User Vibe

[
  {
    "key": "ctrl+d",
    "command": "/dev-doctor",
    "description": "Run Environment Health Check"
  },
  {
    "key": "ctrl+s",
    "command": "/save-state",
    "description": "Snapshot Context State"
  },
  {
    "key": "ctrl+p",
    "command": "/plan-epic",
    "description": "Draft Action Graph"
  },
  {
    "key": "ctrl+r",
    "command": "/tribunal-review",
    "description": "Trigger PR Swarm Review"
  },
  {
    "key": "ctrl+h",
    "command": "/hive-swarm",
    "description": "Spawn Hive Orchestrator"
  },
  {
    "key": "ctrl+g",
    "command": "/grill-me",
    "description": "Staff Engineer Interrogation"
  }
]
